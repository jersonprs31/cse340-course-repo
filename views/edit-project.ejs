<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <!-- Action points to the POST route with the specific project ID -->
    <form action="/edit-project/<%= project.project_id %>" method="POST">
        
        <div class="form-group">
            <label for="title">Project Title</label>
            <input type="text" id="title" name="title" value="<%= project.title %>" required />
        </div>

        <div class="form-group">
            <label for="organization_id">Partner Organization</label>
            <select id="organization_id" name="organization_id" required>
                <% organizations.forEach(org => { %>
                    <!-- The ternary operator checks if this org is the project's current org, and selects it if true -->
                    <option value="<%= org.organization_id %>" <%= org.organization_id === project.organization_id ? 'selected' : '' %>>
                        <%= org.name %>
                    </option>
                <% }); %>
            </select>
        </div>

        <div class="form-group">
            <label for="date">Date</label>
            <!-- Dates must be formatted as YYYY-MM-DD to pre-fill an HTML date input -->
            <% const formattedDate = project.date.toISOString().split('T')[0]; %>
            <input type="date" id="date" name="date" value="<%= formattedDate %>" required />
        </div>

        <div class="form-group">
            <label for="location">Location</label>
            <input type="text" id="location" name="location" value="<%= project.location %>" />
        </div>

        <div class="form-group">
            <label for="venue">Venue</label>
            <input type="text" id="venue" name="venue" value="<%= project.venue %>" />
        </div>

        <div class="form-group">
            <label for="description">Description</label>
            <textarea id="description" name="description" required><%= project.description %></textarea>
        </div>

        <button type="submit">Update Project</button>
    </form>
</main>
<%- include('partials/footer') %>