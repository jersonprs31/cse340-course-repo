<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>
        
        <p>Here are a few of our partner organizations:</p>
        <ul>
            <% organizations.forEach(organization => { %>
                <li>
                    <img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo">
                    <br>
                    <strong><a href="/organization/<%= organization.organization_id %>"><%= organization.name %></a></strong>
                    <p>Email: <%= organization.contact_email %></p>
                    <p><%= organization.description %></p>
                </li>
            <% }); %>
        </ul>

        
        <p style="margin-top: 2rem;">
            <a href="/new-organization" style="font-weight: bold; text-decoration: underline;"> new organization</a>
        </p>
    </main>
<%- include('partials/footer') %>
    </main>
<%- include('partials/footer') %>