<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>
        <p>Service projects in this category:</p>
        
        <% if (projects.length > 0) { %>
            <ul>
                <% projects.forEach(project => { %>
                    <li>
                        <strong><a href="/project/<%= project.project_id %>"><%= project.title %></a></strong>
                        <br>
                        Host: <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>
                    </li>
                <% }); %>
            </ul>
        <% } else { %>
            <p>No upcoming projects available in this category.</p>
        <% } %>
    </main>
<%- include('partials/footer') %>