<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>
        
        <div class="projects-grid">
            <% projects.forEach(project => { %>
                <div class="project-card">
                    <!-- The title now links to the individual project page -->
                    <h2><a href="/project/<%= project.project_id %>"><%= project.title %></a></h2>
                    
                    <!-- The organization name now links to the organization page -->
                    <p>
                        <strong>Host:</strong> 
                        <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>
                    </p>
                    
                    <p><strong>Date:</strong> <%= project.date.toDateString() %></p>
                </div>
            <% }); %>
        </div>
    </main>
<%- include('partials/footer') %>