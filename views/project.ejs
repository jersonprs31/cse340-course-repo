<%- include('partials/header') %>
    <main>
        <div class="project-details">
            <h1><%= project.title %></h1>
            
            
            <p style="margin-top: -10px; margin-bottom: 20px;">
                <a href="/edit-project/<%= project.project_id %>" style="font-weight: bold; color: #0056b3; text-decoration: none;">[ Edit Project ]</a>
            </p>
            
            <p><strong>Date:</strong> <%= project.date.toDateString() %></p>
            
            
            <p><strong>Location:</strong> <%= project.location %></p>
            <p><strong>Venue:</strong> <%= project.venue %></p>
            
            <p>
                <strong>Partner Organization:</strong> 
                <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>
            </p>
            
            <div class="description">
                <p><%= project.description %></p>
            </div>

           
            <hr style="margin: 30px 0; border: 0; border-top: 1px solid #ccc;">

           
            <div class="category-tags" style="margin-bottom: 1rem;">
                <p><strong>This project belongs to the following categories:</strong></p>
                <ul style="list-style-type: none; padding: 0;">
                    <% if (categories && categories.length > 0) { %>
                        <% categories.forEach(cat => { %>
                            <li style="display: inline-block; margin-right: 10px; margin-bottom: 10px;">
                                <a href="/category/<%= cat.category_id %>" style="text-decoration: none; background-color: #e9ecef; color: #333; padding: 5px 12px; border-radius: 15px; font-size: 0.9em;">
                                    <%= cat.category_name %>
                                </a>
                            </li>
                        <% }); %>
                    <% } else { %>
                        <li><em>No categories assigned yet.</em></li>
                    <% } %>
                </ul>
            </div>
        </div>
    </main>
<%- include('partials/footer') %>